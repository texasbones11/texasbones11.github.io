---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Define the props for the component
export interface Props {
  headshotUrl: ImageMetadata;
  name: string;
  tagline: string;
  description: string;
}

// Destructure the props
const { headshotUrl, name, tagline, description } = Astro.props;
---

<section class="aboutme">
  <div class="aboutme-content">
    <!-- Headshot Image -->
    <Image
      src={headshotUrl}
      alt={`Headshot of ${name}`}
      width={150}
      height={150}
      class="aboutme-headshot"
      loading={"lazy"}
    />

    <!-- Text Content -->
    <div class="aboutme-text">
      <h1 class="aboutme-name">{name}</h1>
      <p class="aboutme-tagline">{tagline}</p>
      <p class="aboutme-description">{description}</p>
    </div>
  </div>
</section>

<style>
  /* About me Section Styles */
  .aboutme {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    text-align: center;
    background: #f9f9f9; /* Optional: Add a background color */
  }

  .aboutme-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* Headshot Styles */
  .aboutme-headshot {
    width: 150px;
    height: 150px;
    border-radius: 50%; /* Circular headshot */
    object-fit: cover; /* Ensures the image fits well */
    border: 4px solid #fff; /* Optional: Add a border */
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Subtle shadow */
  }

  /* Text Styles */
  .aboutme-name {
    font-size: 2.5rem;
    margin: 0;
  }

  .aboutme-tagline {
    font-size: 1.5rem;
    margin: 0;
    color: #666; /* Optional: Add a subtle color */
  }

  .aboutme-description {
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 600px;
    color: #444; /* Optional: Add a subtle color */
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .aboutme {
      padding: 1.5rem;
    }

    .aboutme-name {
      font-size: 2rem;
    }

    .aboutme-tagline {
      font-size: 1.25rem;
    }

    .aboutme-description {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .aboutme {
      padding: 1rem;
    }

    .aboutme-name {
      font-size: 1.75rem;
    }

    .aboutme-tagline {
      font-size: 1.1rem;
    }

    .aboutme-description {
      font-size: 0.9rem;
    }
  }
</style>
