---
import awsCostImage from "../assets/background.svg";
import soc2Image from "../assets/background.svg";
import k8sImage from "../assets/background.svg";
import aiDevopsImage from "../assets/background.svg";
import { Image } from "astro:assets";
---

<section class="cards-section">
  <div class="cards-container">
    <a href="/modernsoc2" class="card">
      <div class="image-container">
        <Image
          src={soc2Image}
          alt="Modern SOC 2 compliance"
          width={300}
          height={160}
        />
      </div>
      <div class="text-content">
        <h2>Building Trust While Shipping Fast</h2>
        <p>SOC 2 Compliance Without Compromising Innovation</p>
      </div>
    </a>

    <a href="/cloudcostsaving" class="card">
      <div class="image-container">
        <Image
          src={awsCostImage}
          alt="Cloud cost saving"
          width={300}
          height={160}
        />
      </div>
      <div class="text-content">
        <h2>Cloud Cost Control Without Compromise</h2>
        <p>30% AWS Savings While Improving Reliability</p>
      </div>
    </a>

    <a href="/kubernetesmigration" class="card">
      <div class="image-container">
        <Image
          src={k8sImage}
          alt="Kubernetes Migration"
          width={300}
          height={160}
        />
      </div>
      <div class="text-content">
        <h2>Mission-Critical Infrastructure Modernization</h2>
        <p>From Technical Debt to Reliable Foundations in 90 Days</p>
      </div>
    </a>

    <a href="/aiefficiency" class="card">
      <div class="image-container">
        <Image
          src={aiDevopsImage}
          alt="AI Efficiency in DevOps"
          width={300}
          height={160}
        />
      </div>
      <div class="text-content">
        <h2>AI That Cuts the Busywork</h2>
        <p>How We Freed Engineers to Focus on What Matters</p>
      </div>
    </a>
  </div>
</section>

<style>
  .cards-section {
    padding: 2rem;
    background: #f9f9f9;
  }

  .cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .card {
    flex: 1 1 calc(33.333% - 1.5rem);
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    height: 300px;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .image-container {
    height: 160px;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .text-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .text-content h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: #333;
  }

  .text-content p {
    font-size: 0.95rem;
    color: #666;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .card {
      flex: 1 1 calc(50% - 1.5rem);
    }
  }

  @media (max-width: 480px) {
    .card {
      flex: 1 1 100%;
      height: 380px;
    }
  }
</style>
