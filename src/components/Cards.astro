// No props or dynamic data needed for this example
---

<section class="cards-section">
  <div class="cards-container">
    <a href="s/page1" class="card">
      <h2>Scaling Infrastructure for Rapid Growth</h2>
      <p>This is the first card. Click to go to Page 1.</p>
    </a>
    <a href="s/page2" class="card">
      <h2>Driving Security as a Business Enabler</h2>
      <p>This is the second card. Click to go to Page 2.</p>
    </a>
    <a href="/page3" class="card">
      <h2>Leading a High-Performing DevOps Team</h2>
      <p>This is the third card. Click to go to Page 3.</p>
    </a>
    <a href="/page4" class="card">
      <h2>Automating Manual Processes</h2>
      <p>This is the fourth card. Click to go to Page 4.</p>
    </a>
  </div>
</section>

<style>
  .cards-section {
    padding: 2rem;
    background: #f9f9f9; /* Optional: Add a background color */
  }

  .cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    max-width: 1200px; /* Limit the width of the container */
    margin: 0 auto; /* Center the container horizontally */
  }

  .card {
    flex: 1 1 calc(33.333% - 1.5rem);
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    text-decoration: none;
    color: #333;
    height: 300px; /* Set a fixed height for the cards */
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 1rem;
    color: #666;
  }

  @media (max-width: 768px) {
    .card {
      flex: 1 1 calc(50% - 1.5rem); /* Two cards per row on tablets */
    }
  }

  @media (max-width: 480px) {
    .card {
      flex: 1 1 100%; /* One card per row on mobile */
    }
  }
</style>
