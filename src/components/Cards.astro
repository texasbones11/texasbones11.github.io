---
// No props or dynamic data needed for this example
---

<section class="cards-section">
  <div class="cards-container">
    <a href="/page1" class="card">
      <h2>Card 1</h2>
      <p>This is the first card. Click to go to Page 1.</p>
    </a>
    <a href="/page2" class="card">
      <h2>Card 2</h2>
      <p>This is the second card. Click to go to Page 2.</p>
    </a>
    <a href="/page3" class="card">
      <h2>Card 3</h2>
      <p>This is the third card. Click to go to Page 3.</p>
    </a>
  </div>
</section>

<style>
  .cards-section {
    padding: 2rem;
    height: 50vh;
  }

  .cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .card {
    flex: 1 1 calc(33.333% - 1.5rem);
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    text-decoration: none;
    color: #333;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 1rem;
    color: #666;
  }

  @media (max-width: 768px) {
    .card {
      flex: 1 1 calc(50% - 1.5rem);
    }
  }

  @media (max-width: 480px) {
    .card {
      flex: 1 1 100%;
    }
  }
</style>
