---
// No props or dynamic data needed for this example
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">I'm Will Jones</h1>

    <p class="hero-description">
      I build
      <span class="text-container">
        <span class="animated-text fast">fast</span>
        <span class="animated-text stuff">stuff</span>
      </span>
      - driving innovation and delivering impact
    </p>

    <!-- Bullet Points -->
    <ul class="experience-list">
      <li>5+ years leading high-performing teams</li>
      <li>10+ years designing and building secure, scalable systems</li>
      <li>Transforming great ideas into reality</li>
    </ul>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: flex-start; /* Align content to the top */
    align-items: flex-start; /* Align content to the left */
    padding: 4rem; /* Add padding to the top and left */
    position: relative;
    overflow: hidden; /* Ensure the blurred edges don't overflow */
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("../assets/background-tech.webp"); /* Replace with your image path */
    background-size: cover;
    background-position: center;
    filter: blur(10px); /* Adjust blur intensity */
    z-index: -1; /* Place the background behind the content */
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%; /* Adjust the fade height */
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0) 30%,
      #f9f9f9 80%,
      #f9f9f9 100%
    ); /* Fade to white */
    z-index: 0; /* Place the gradient above the background */
  }

  .hero-content {
    position: relative;
    z-index: 1; /* Place the content above the background and gradient */
    /*text-align: center;*/
    color: #2e2e2e; /* Dark gray font color */
    padding: 2rem;
  }

  .hero-title {
    font-size: 4rem; /* Adjusted font size */
    font-weight: bold;
    /*text-align: center;*/
    margin: 0;
    line-height: 1.1;
    max-width: 100%; /* Prevent text from stretching too far */
  }

  .hero-description {
    position: relative;
    /*text-align: center;*/
    align-items: flex-start; /* Align content to the left */
    font-size: 1.5rem; /* Adjusted font size */
    margin-top: 1rem; /* Add space between the title and description */
  }

  .text-container {
    display: inline-flex;
    align-items: center;
    position: relative;
    overflow: visible; /* Allow overflow to prevent cutting off text */
    gap: 0.3rem; /* Add space between "fast" and "stuff" */
  }

  .animated-text {
    position: relative;
    display: inline-block;
    white-space: nowrap; /* Prevent text from wrapping */
  }

  .fast {
    animation: moveRight 7s infinite; /* Move "fast" to the right */
    font-weight: bold;
    color: #2c7a7b;
  }

  .stuff {
    animation: moveLeft 7s infinite; /* Move "stuff" to the left */
  }

  /* Experience List Styles */
  .experience-list {
    margin-top: 1.5rem; /* Space between description and list */
    padding-left: 1.5rem; /* Indent bullet points */
    list-style-type: disc; /* Add bullet points */
    font-size: 1.25rem;
    color: #2e2e2e; /* Slightly transparent text */
  }

  .experience-list li {
    margin-bottom: 0.5rem; /* Space between list items */
  }

  @keyframes moveRight {
    0%,
    38% {
      transform: translateX(0); /* Start position: before "stuff" */
    }
    40%,
    93% {
      transform: translateX(
        calc(95% + 0.65rem)
      ); /* Move to the right, after "stuff" */
    }
    95%,
    100% {
      transform: translateX(0); /* Return to start position */
    }
  }

  @keyframes moveLeft {
    0%,
    38% {
      transform: translateX(0); /* Start position: after "fast" */
    }
    40%,
    93% {
      transform: translateX(
        calc(-88% - 0.5rem)
      ); /* Move to the left, before "fast" */
    }
    95%,
    100% {
      transform: translateX(0); /* Return to start position */
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 1rem; /* Add padding to the top and left */
    }

    .hero-title {
      font-size: 3rem; /* Adjusted for tablets */
    }

    .hero-description {
      font-size: 1.25rem; /* Adjusted for tablets */
    }

    .text-container {
      gap: 0.3rem; /* Adjust spacing for smaller screens */
    }

    .experience-list {
      font-size: 1.1rem;
    }

    @keyframes moveRight {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(
          calc(95% + 0.5rem)
        ); /* Adjusted for smaller screens */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }

    @keyframes moveLeft {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(
          calc(-85% - 0.5rem)
        ); /* Adjusted for smaller screens */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 1rem; /* Add padding to the top and left */
    }

    .hero-title {
      font-size: 2.5rem; /* Adjusted for mobile */
      max-width: 90%; /* Adjust for smaller screens */
    }

    .hero-description {
      font-size: 1rem; /* Adjusted for mobile */
    }

    .text-container {
      gap: 0.3rem; /* Adjust spacing for mobile */
    }

    .experience-list {
      font-size: 1rem;
    }

    @keyframes moveRight {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(calc(95% + 0.5rem)); /* Adjusted for mobile */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }

    @keyframes moveLeft {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(calc(-85% - 0.5rem)); /* Adjusted for mobile */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }
  }
</style>
