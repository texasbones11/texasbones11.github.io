---
// No props or dynamic data needed for this example
---

<section class="hero">
  <h1 class="hero-title">I'm Will Jones</h1>
  <p class="hero-description">
    I build
    <span class="text-container">
      <span class="animated-text fast">fast</span>
      <span class="animated-text stuff">stuff</span>
    </span>
  </p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: flex-start; /* Align content to the top */
    align-items: flex-start; /* Align content to the left */
    height: 40vh; /* Set a fixed height for the hero section */
    padding: 2rem; /* Add padding to the top and left */
    background: linear-gradient(
      135deg,
      #1e3c72 0%,
      #2a5298 100%
    ); /* Optional: Add a background */
    color: white;
  }

  .hero-title {
    font-size: 4rem; /* Adjusted font size */
    font-weight: bold;
    margin: 0;
    line-height: 1.1;
    max-width: 80%; /* Prevent text from stretching too far */
  }

  .hero-description {
    font-size: 1.5rem; /* Adjusted font size */
    margin-top: 1rem; /* Add space between the title and description */
  }

  .text-container {
    display: inline-flex;
    align-items: center;
    position: relative;
    overflow: visible; /* Allow overflow to prevent cutting off text */
    gap: 0.5rem; /* Add space between "fast" and "stuff" */
  }

  .animated-text {
    position: relative;
    display: inline-block;
    white-space: nowrap; /* Prevent text from wrapping */
  }

  .fast {
    animation: moveRight 7s infinite; /* Move "fast" to the right */
    font-weight: bold;
  }

  .stuff {
    animation: moveLeft 7s infinite; /* Move "stuff" to the left */
  }

  @keyframes moveRight {
    0%,
    38% {
      transform: translateX(0); /* Start position: before "stuff" */
    }
    40%,
    93% {
      transform: translateX(
        calc(100% + 0.75rem)
      ); /* Move to the right, after "stuff" */
    }
    95%,
    100% {
      transform: translateX(0); /* Return to start position */
    }
  }

  @keyframes moveLeft {
    0%,
    38% {
      transform: translateX(0); /* Start position: after "fast" */
    }
    40%,
    93% {
      transform: translateX(
        calc(-90% - 0.5rem)
      ); /* Move to the left, before "fast" */
    }
    95%,
    100% {
      transform: translateX(0); /* Return to start position */
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 3rem; /* Adjusted for tablets */
    }

    .hero-description {
      font-size: 1.25rem; /* Adjusted for tablets */
    }

    .text-container {
      gap: 0.75rem; /* Adjust spacing for smaller screens */
    }

    @keyframes moveRight {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(
          calc(100% + 0.75rem)
        ); /* Adjusted for smaller screens */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }

    @keyframes moveLeft {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(
          calc(-90% - 0.75rem)
        ); /* Adjusted for smaller screens */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2.5rem; /* Adjusted for mobile */
      max-width: 90%; /* Adjust for smaller screens */
    }

    .hero-description {
      font-size: 1rem; /* Adjusted for mobile */
    }

    .text-container {
      gap: 0.5rem; /* Adjust spacing for mobile */
    }

    @keyframes moveRight {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(calc(100% + 0.5rem)); /* Adjusted for mobile */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }

    @keyframes moveLeft {
      0%,
      38% {
        transform: translateX(0);
      }
      40%,
      93% {
        transform: translateX(calc(-90% - 0.5rem)); /* Adjusted for mobile */
      }
      95%,
      100% {
        transform: translateX(0);
      }
    }
  }
</style>
