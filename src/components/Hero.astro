---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Define the props for the component
export interface Props {
  headshotUrl: ImageMetadata;
  name: string;
  tagline: string;
  description: string;
}

// Destructure the props
const { headshotUrl, name, tagline, description } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <!-- Headshot Image -->
    <div class="hero-headshot">
      <Image
        src={headshotUrl}
        alt={`Headshot of ${name}`}
        width={150}
        height={150}
        class="hero-headshot"
        loading={"eager"}
      />
    </div>

    <!-- Text Content -->
    <div class="hero-text">
      <h1 class="hero-name">{name}</h1>
      <p class="hero-tagline">{tagline}</p>
      <p class="hero-description">{description}</p>
    </div>
  </div>
</section>

<style>
  /* Hero Section Styles */
  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh; /* Full viewport height */
    background-color: #f0f0f0; /* Light gray background */
    padding: 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* Headshot Styles */
  .hero-headshot {
    width: 150px;
    height: 150px;
    border-radius: 50%; /* Circular headshot */
    object-fit: cover; /* Ensures the image fits well */
    border: 4px solid #fff; /* Optional: Add a border */
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Subtle shadow */
  }

  /* Text Styles */
  .hero-name {
    font-size: 2.5rem;
    margin: 0;
    color: #333; /* Dark gray text */
  }

  .hero-tagline {
    font-size: 1.5rem;
    margin: 0;
    color: #666; /* Medium gray text */
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #444; /* Slightly lighter gray text */
    max-width: 600px;
  }
</style>
