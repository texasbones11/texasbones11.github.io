---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Define the props for the component
export interface Props {
  casepicUrl: ImageMetadata;
  name: string;
  tagline: string;
  description: string;
}

// Destructure the props
const { casepicUrl, name, tagline, description } = Astro.props;
---

<!-- Back Button Container -->
<div class="back-button-container">
  <a href="/" class="back-button">← Back to Main Page</a>
</div>

<!-- Hero Section -->
<section class="page-hero">
  <h1 class="page-title">{name}</h1>
  <p class="page-description">{tagline}</p>
</section>

<!-- Content Section -->
<section class="page-content">
  <div class="content-container">
    <h2>Overview</h2>
    <p>{description}</p>

    <h2>Architecture Diagram</h2>
    <div class="diagram-container">
      <Image
        src={casepicUrl}
        alt={tagline}
        class="architecture-diagram"
        loading={"eager"}
      />
      <p class="diagram-caption">
        Figure 1: High-level architecture for scalable infrastructure.
      </p>
    </div>

    <h2>Key Strategies</h2>
    <ul>
      <li>
        **Modular Architecture**: Breaking down systems into smaller,
        independent components.
      </li>
      <li>
        **Automation**: Implementing CI/CD pipelines to streamline deployments.
      </li>
      <li>
        **Monitoring and Alerts**: Using tools like Prometheus and Grafana to
        track system health.
      </li>
    </ul>

    <h2>Case Study</h2>
    <p>
      One of my recent projects involved scaling the infrastructure for a SaaS
      platform that grew from 10,000 to 1,000,000 users in under a year. By
      leveraging cloud-native technologies and optimizing database performance,
      we achieved 99.9% uptime and reduced latency by 40%.
    </p>
  </div>
</section>

<style>
  /* Back Button Container Styles */
  .back-button-container {
    background: #e8f0f7; /* Light gray background */
  }

  /* Back Button Styles */
  .back-button {
    display: inline-block;
    margin: 1rem;
    padding: 0.5rem 1rem;
    background: #1e3c72; /* Deep blue accent */
    color: white;
    border-radius: 4px;
    text-decoration: none;
    font-size: 1rem;
    transition: background 0.3s ease;
    font-family: "Inter", sans-serif; /* Button font */
  }

  .back-button:hover {
    background: #152a4d; /* Darker blue on hover */
  }

  /* Page Hero Styles */
  .page-hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    height: 30vh;
    padding: 2rem;
    background: linear-gradient(
      to bottom,
      #e8f0f7 0%,
      #e8f0f7 50%,
      #f9f9f9 90%,
      #f9f9f9 100%
    ); /* Optional: Add a background */
    color: #2e2e2e; /* Dark gray font color */
  }

  .page-title {
    font-size: 3rem;
    font-weight: bold;
    margin: 0;
    line-height: 1.1;
    font-family: "Inter", sans-serif; /* Headline font */
  }

  .page-description {
    font-size: 1.25rem;
    margin-top: 1rem;
    font-family: "Lato", sans-serif; /* Body font */
  }

  /* Page Content Styles */
  .page-content {
    padding: 2rem;
    background: #f9f9f9; /* White background */
  }

  .content-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .content-container h2 {
    font-size: 2rem;
    font-weight: bold;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-family: "Inter", sans-serif; /* Headline font */
  }

  .content-container p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-family: "Lato", sans-serif; /* Body font */
  }

  .content-container ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .content-container li {
    margin-bottom: 0.5rem;
  }

  /* Diagram Styles */
  .diagram-container {
    margin: 2rem 0;
    text-align: center;
  }

  .architecture-diagram {
    max-width: 100%;
    height: auto;
    border: 1px solid #e0e0e0; /* Optional: Add a border */
    border-radius: 8px; /* Optional: Add rounded corners */
  }

  .diagram-caption {
    font-size: 0.9rem;
    color: #666;
    margin-top: 0.5rem;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .page-title {
      font-size: 2.5rem;
    }

    .page-description {
      font-size: 1.1rem;
    }

    .content-container h2 {
      font-size: 1.75rem;
    }

    .content-container p {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .page-title {
      font-size: 2rem;
    }

    .page-description {
      font-size: 1rem;
    }

    .content-container h2 {
      font-size: 1.5rem;
    }

    .content-container p {
      font-size: 0.9rem;
    }
  }
</style>
