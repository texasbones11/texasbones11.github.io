---
import Casestudy from "../components/Casestudy.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Casepic from "../assets/background.svg";

// Define the props for the Hero component
//const headshotUrl = "../assets/headshot.webp"; // Path to your headshot image
const name = "Scaling Kubernetes to Enterprise-Grade Reliability";
const tagline = `A Battle-Tested Approach to Cloud Infrastructure`;
const description = `When platform reliability directly impacts customer trust, infrastructure decisions become business-critical. 
This case study reveals how I transformed a fragile Kubernetes deployment into a resilient foundation for global workloads.`;

const challenge = `The Challenge: Fragile Infrastructure at Scale`;
const challengepart1 = `Frequent control plane instability during peak loads (3-5 incidents/month causing 15+ minute outages)`;
const solution = `The Solution: Reliability Engineering Framework`;
const solutionpart1 = `Designed and implemented a multi-az Kubernetes control plane using etcd optimization techniques and node auto-repair workflows. 
Built custom operators in Go to automate recovery from 23 common failure modes identified through chaos engineering experiments. 
Reduced mean-time-to-recovery (MTTR) from 17 minutes to 42 seconds for critical failure scenarios.`;

const challengepart2 = `Inconsistent deployment patterns across teams led to "snowflake" clusters`;
const solutionpart2 = `Created standardized platform abstractions using Kubernetes Operators and Helm charts, enforcing 12 key reliability 
patterns (e.g., pod disruption budgets, topology spread constraints). Implemented GitOps workflows with ArgoCD that reduced 
configuration drift by 89% while giving developers self-service capabilities.`;

const challengepart3 = `No capacity planning framework resulted in either wasteful overprovisioning or risky undercapacity`;
const picturedescription = `Architecture diagram showing resilient Kubernetes control plane with (1) Multi-AZ etcd (2) Automated healing (3) Capacity buffers`;
---

<Layout>
  <Casestudy
    casepicUrl={Casepic}
    name={name}
    tagline={tagline}
    description={description}
    challenge={challenge}
    solution={solution}
    challengepart1={challengepart1}
    solutionpart1={solutionpart1}
    challengepart2={challengepart2}
    solutionpart2={solutionpart2}
    challengepart3={challengepart3}
    picturedescription={picturedescription}
  />
</Layout>
<Footer />
