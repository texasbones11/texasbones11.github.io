---
import Casestudy from "../components/Casestudy.astro";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Casepic from "../assets/background.svg";

// Define the props for the Hero component
//const headshotUrl = "../assets/headshot.webp"; // Path to your headshot image
const name = "AI-Powered DevOps: Engineering Productivity at Scale";
const tagline = `How Automation Can 10X Your Team's Output`;
const description = `For technical leaders at scaling startups, engineering velocity is the ultimate competitive advantage. 
This case study reveals how strategic automation and AI adoption transformed developer workflows.`;

const challenge = `The Challenge: Bottlenecks in Developer Productivity`;
const challengepart1 = `Manual testing processes created 3-4 day delays in release cycles (40+ hours of engineer time/week)`;
const solution = `The Solution: Intelligent Automation Framework`;
const solutionpart1 = `Built an AI-assisted testing pipeline using open-source LLMs to generate test cases from Jira tickets, reducing test creation time by 65%. 
Implemented flaky test detection with anomaly scoring to prioritize reliability fixes. Containerized the entire testing environment 
using Kubernetes for reproducible test execution across 300+ microservices.`;

const challengepart2 = `Code review backlogs stretched to 5-7 days, slowing feature development`;
const solutionpart2 = `Developed an automated code review system combining static analysis tools with custom rulesets trained on historical PR data. 
The AI co-pilot surface contextual suggestions (security fixes, performance optimizations) directly in GitHub PRs, 
reducing average review time from 48 hours to 6 hours while improving defect catch rate by 28%.`;

const challengepart3 = `On-call fatigue from production incidents caused burnout and turnover risk`;
const picturedescription = `Workflow diagram showing (1) AI test generation (2) Smart monitoring (3) Automated remediation`;
---

<Layout>
  <Casestudy
    casepicUrl={Casepic}
    name={name}
    tagline={tagline}
    description={description}
    challenge={challenge}
    solution={solution}
    challengepart1={challengepart1}
    solutionpart1={solutionpart1}
    challengepart2={challengepart2}
    solutionpart2={solutionpart2}
    challengepart3={challengepart3}
    picturedescription={picturedescription}
  />
</Layout>
<Footer />
