---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Cards from "../components/Cards.astro";
import Aboutme from "../components/Aboutme.astro";
import Headshot from "../assets/headshot.webp";

// Define the props for the Hero component
//const headshotUrl = "../assets/headshot.webp"; // Path to your headshot image
const name = "Will Jones";
const tagline = "DevOps & Security Leader";
const description =
  "Building scalable solutions with a focus on innovation and impact.";
---

<Layout>
  <Hero />
  <Cards />
  <Aboutme
    headshotUrl={Headshot}
    name={name}
    tagline={tagline}
    description={description}
  />
</Layout>
